# Frontend config — NON-SECRET values only.
# VITE_* vars are inlined into the JS bundle at build time and are PUBLIC (07b slide 25).
# Never put a client_secret, API key, or any credential here — the SPA is a public OIDC
# client and authenticates with PKCE, which needs no secret.

# Keycloak OIDC issuer (realm URL)
VITE_KEYCLOAK_ISSUER=http://localhost:8081/realms/eurotransit

# Public OIDC client id (public client, PKCE)
VITE_KEYCLOAK_CLIENT_ID=eurotransit-frontend

# API base path — relative, same-origin through the gateway (no CORS wildcard needed)
VITE_API_BASE=/api
